# ── Chat Frontend Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in the values before running locally.
# On Render, the frontend is built as part of the chat-backend service build step.
# Pass these as build-time env vars in the Render dashboard or render.yaml.
# All VITE_ variables are baked into the JS bundle at build time.

# Base URL of the main Sentinel API backend
# Local dev: http://localhost:5000
# Production: https://sentinel.onrender.com  (your Render URL)
VITE_API_URL=http://localhost:5000

# Full public URL of the main Sentinel marketplace website
# Local dev: http://localhost:5173
# Production: https://sentinel.onrender.com
VITE_SENTINAL_MARKETPLACE_URL=http://localhost:5173

# Chat backend URL override (optional — leave blank in production because
# the chat-front is served from the same origin as the chat-backend)
# Local dev: (leave blank — the vite dev server proxies /api → 4000)
VITE_CHAT_BACKEND_URL=

# ── Firebase (required for Google Sign-In) ─────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
