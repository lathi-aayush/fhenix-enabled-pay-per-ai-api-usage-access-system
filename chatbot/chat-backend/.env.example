# ── Chat Backend Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in the values before running locally.
# On Render, set these as Environment Variables in the service dashboard
# or via render.yaml (sync: false means you supply them manually).

# Port the Express server listens on (Render injects this automatically)
PORT=4000

# Set to "production" on Render (render.yaml sets this automatically)
NODE_ENV=development

# MongoDB connection string for the Chat database
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>

# JWT secret — MUST match the JWT_SECRET used by the main Sentinel backend
# so tokens issued there can be verified here
JWT_SECRET=your_jwt_secret_here

# Base URL of the main Sentinel API backend
# Local dev: http://localhost:5000
# Production: https://sentinel.onrender.com  (or your Render URL)
SENTINAL_API_URL=http://localhost:5000

# CORS — the origin of the main Sentinel marketplace frontend
# Only needed in production (leave blank for local dev)
FRONTEND_ORIGIN=

# ── Firebase Admin (optional) ──────────────────────────────────────────────────
# Leave blank to run in JWT-only mode (no Firebase verification).
# Set FIREBASE_PROJECT_ID at minimum if you want real token verification.
FIREBASE_PROJECT_ID=
# Paste the full contents of your Firebase service account JSON as a single line:
FIREBASE_SERVICE_ACCOUNT_JSON=
