# ── Local dev (npm run dev) ────────────────────────────────────────────────────
# Leave VITE_API_URL unset — Vite proxies /api to the backend automatically.
# VITE_PROXY_TARGET=http://localhost:5001

# ── Production build ──────────────────────────────────────────────────────────
# VITE_API_URL=https://your-backend.onrender.com

# ── Base Sepolia network ─────────────────────────────────────────────────────
VITE_RPC_URL=https://sepolia.base.org
VITE_CHAIN_ID=84532

# SentinelPayment contract address (set after deploying contract/)
# VITE_CONTRACT_ADDRESS=0x...

# Treasury/receiver wallet (shown in UI for marketplace payments)
# VITE_TREASURY_WALLET=0x...
# VITE_RECEIVER_WALLET=0x...

# Optional: override the public site URL for blog links
# VITE_PUBLIC_SITE_URL=https://sentinalai.dev
