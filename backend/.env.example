# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/sentinal-fhenix

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# ── Base Sepolia / EVM ────────────────────────────────────────────────────────
# Public Base Sepolia RPC (free: https://sepolia.base.org or Alchemy/Infura)
RPC_URL=https://sepolia.base.org
CHAIN_ID=84532

# Treasury wallet — receives marketplace platform fees (EVM 0x address)
TREASURY_WALLET_ADDRESS=0x...
RECEIVER_WALLET=0x...

# Treasury private key — for server-side payments (never commit)
# TREASURY_PRIVATE_KEY=0x...

# SentinelPayment contract — auto-loaded from contract/contract_info.json if unset
# CONTRACT_ADDRESS=0x...

# Minimum deposit to SentinelPayment contract (in wei, default 0.001 ETH)
# MIN_DEPOSIT_WEI=1000000000000000

# ── Studio exchange rates ─────────────────────────────────────────────────────
ETH_USD_RATE=3200
INR_USD_RATE=84.50

# Studio credits per plan tier
STUDIO_CREDIT_FREE=15
STUDIO_CREDIT_CREATOR=120
STUDIO_CREDIT_PRO=400
STUDIO_CREDIT_ENTERPRISE=1500

# Studio overage prices (in ETH)
STUDIO_OVERAGE_LITE_ETH=0.0002
STUDIO_OVERAGE_BLOG_ETH=0.0003
STUDIO_OVERAGE_CREATIVE_ETH=0.001
STUDIO_OVERAGE_AGENTIC_MED_ETH=0.002
STUDIO_OVERAGE_AGENTIC_FULL_ETH=0.005

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# REDIS_DISABLED=1

# ── Encryption ────────────────────────────────────────────────────────────────
# Exactly 32 characters — used for AES-256-GCM encryption of provider API keys
ENCRYPTION_KEY=your_32_char_encryption_key_here

# ── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173
# CORS_ALLOWED_ORIGINS=https://sentinalai.dev,https://www.sentinalai.dev

# ── AI Providers ─────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Vertex AI (Imagen + Veo)
# GOOGLE_CLOUD_PROJECT=your_gcp_project_id
# GOOGLE_APPLICATION_CREDENTIALS=../your-service-account.json
# VERTEX_API_KEY=your_vertex_api_key_here
# VERTEX_LOCATION=us-central1
# VERTEX_IMAGEN_ENABLED=false
# VERTEX_IMAGEN_MODEL=imagen-3.0-generate-002
# VEO_MODEL_IDS=veo-3.1-fast-generate-001,veo-2.0-generate-001

# GCS for generated assets
# GCS_ASSETS_BUCKET=your-bucket-name
# GCS_ASSET_PREFIX=sentinal
# GCS_SIGNED_URL_TTL_SEC=3600

# ── ClipCraft ─────────────────────────────────────────────────────────────────
CLIPCRAFT_ENABLED=true
CLIPCRAFT_PROVIDER_MODE=mock
CLIPCRAFT_MAX_CONCURRENT_JOBS=4
CLIPCRAFT_JOB_TIMEOUT_MS=300000
CLIPCRAFT_MAX_RETRIES=3
CLIPCRAFT_RETRY_BACKOFF_MS=2000
CLIPCRAFT_CREDITS_PER_PACK=1.5
CLIPCRAFT_BULK_PACK_THRESHOLD=10
CLIPCRAFT_BULK_PACK_TOTAL_CREDITS=12
CLIPCRAFT_VIRAL_SURCHARGE_PER_PACK=0.2
CLIPCRAFT_JOB_QUEUE_ADAPTER=memory
CLIPCRAFT_PROGRESS_ADAPTER=memory
CLIPCRAFT_RATE_LIMIT_PER_MIN=30
CLIPCRAFT_IDEMPOTENCY_TTL_MS=86400000
CLIPCRAFT_SHUTDOWN_TIMEOUT_MS=30000

# Admin user IDs for COGS report
ADMIN_USER_IDS=
